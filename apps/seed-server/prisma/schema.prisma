generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model attributes {
  attribute_id          Int                     @id @default(autoincrement())
  attribute_type_id     Int
  slug                  String                  @unique(map: "slug") @db.VarChar(50)
  icon                  String?                 @db.VarChar(50)
  attributetypes        attributetypes          @relation(fields: [attribute_type_id], references: [attribute_type_id], onDelete: NoAction, onUpdate: NoAction, map: "attributes_ibfk_1")
  attributetranslations attributetranslations[]
  productattributes     productattributes[]

  @@index([attribute_type_id], map: "attribute_type_id")
}

model attributetranslations {
  translation_id Int        @id @default(autoincrement())
  attribute_id   Int
  language_id    String     @db.Char(2)
  name           String     @db.VarChar(50)
  description    String?    @db.Text
  attributes     attributes @relation(fields: [attribute_id], references: [attribute_id], onDelete: NoAction, onUpdate: NoAction, map: "attributetranslations_ibfk_1")
  languages      languages  @relation(fields: [language_id], references: [language_id], onDelete: NoAction, onUpdate: NoAction, map: "attributetranslations_ibfk_2")

  @@unique([attribute_id, language_id], map: "attribute_id")
  @@index([language_id], map: "language_id")
}

model attributetypes {
  attribute_type_id         Int                         @id @default(autoincrement())
  slug                      String                      @unique(map: "slug") @db.VarChar(50)
  is_filterable             Boolean?                    @default(true)
  attributes                attributes[]
  attributetypetranslations attributetypetranslations[]
}

model attributetypetranslations {
  translation_id    Int            @id @default(autoincrement())
  attribute_type_id Int
  language_id       String         @db.Char(2)
  name              String         @db.VarChar(50)
  attributetypes    attributetypes @relation(fields: [attribute_type_id], references: [attribute_type_id], onDelete: NoAction, onUpdate: NoAction, map: "attributetypetranslations_ibfk_1")
  languages         languages      @relation(fields: [language_id], references: [language_id], onDelete: NoAction, onUpdate: NoAction, map: "attributetypetranslations_ibfk_2")

  @@unique([attribute_type_id, language_id], map: "attribute_type_id")
  @@index([language_id], map: "language_id")
}

model categories {
  category_id          Int                    @id @default(autoincrement())
  slug                 String?                @unique(map: "slug") @db.VarChar(100)
  categorytranslations categorytranslations[]
  subcategories        subcategories[]
}

model categorytranslations {
  translation_id Int        @id @default(autoincrement())
  category_id    Int
  language_id    String     @db.Char(2)
  name           String     @db.VarChar(50)
  description    String?    @db.Text
  categories     categories @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction, map: "categorytranslations_ibfk_1")
  languages      languages  @relation(fields: [language_id], references: [language_id], onDelete: NoAction, onUpdate: NoAction, map: "categorytranslations_ibfk_2")

  @@unique([category_id, language_id], map: "category_id")
  @@index([language_id], map: "language_id")
}

model customeraddresses {
  address_id                                           Int                    @id @default(autoincrement())
  customer_id                                          Int
  type                                                 customeraddresses_type
  street                                               String                 @db.VarChar(100)
  city                                                 String                 @db.VarChar(50)
  zip_code                                             String                 @db.VarChar(20)
  country                                              String                 @db.Char(2)
  is_default                                           Boolean?               @default(false)
  customers                                            customers              @relation(fields: [customer_id], references: [customer_id], onDelete: NoAction, onUpdate: NoAction, map: "customeraddresses_ibfk_1")
  orders_orders_billing_address_idTocustomeraddresses  orders[]               @relation("orders_billing_address_idTocustomeraddresses")
  orders_orders_shipping_address_idTocustomeraddresses orders[]               @relation("orders_shipping_address_idTocustomeraddresses")

  @@index([customer_id], map: "customer_id")
}

model customers {
  customer_id       Int                 @id @default(autoincrement())
  user_id           Int?
  first_name        String              @db.VarChar(50)
  last_name         String              @db.VarChar(50)
  email             String              @unique(map: "email") @db.VarChar(100)
  phone             String?             @db.VarChar(20)
  created_at        DateTime?           @default(now()) @db.Timestamp(0)
  customeraddresses customeraddresses[]
  orders            orders[]
}

model expiryalerts {
  alert_id       Int                     @id @default(autoincrement())
  batch_id       Int
  alert_type     expiryalerts_alert_type
  threshold_days Int
  triggered_at   DateTime?               @default(now()) @db.Timestamp(0)
  is_resolved    Boolean?                @default(false)
  resolved_notes String?                 @db.Text
  productbatches productbatches          @relation(fields: [batch_id], references: [batch_id], onDelete: NoAction, onUpdate: NoAction, map: "expiryalerts_ibfk_1")

  @@index([batch_id], map: "batch_id")
}

model invoices {
  invoice_id     Int       @id @default(autoincrement())
  order_id       Int
  invoice_number String    @unique(map: "invoice_number") @db.VarChar(20)
  issued_at      DateTime? @default(now()) @db.Timestamp(0)
  due_date       DateTime? @db.Date
  tax_number     String?   @db.VarChar(50)
  pdf_path       String?   @db.VarChar(255)
  orders         orders    @relation(fields: [order_id], references: [order_id], onDelete: NoAction, onUpdate: NoAction, map: "invoices_ibfk_1")

  @@index([order_id], map: "order_id")
}

model languages {
  language_id               String                      @id @db.Char(2)
  name                      String                      @db.VarChar(50)
  is_default                Boolean?                    @default(false)
  attributetranslations     attributetranslations[]
  attributetypetranslations attributetypetranslations[]
  categorytranslations      categorytranslations[]
  producttranslations       producttranslations[]
  subcategorytranslations   subcategorytranslations[]
}

model orderitems {
  item_id         Int             @id @default(autoincrement())
  order_id        Int
  product_id      Int
  variant_id      Int
  batch_id        Int
  quantity        Int
  unit_price      Decimal         @db.Decimal(10, 2)
  tax_rate        Decimal         @db.Decimal(5, 2)
  discount_amount Decimal?        @default(0.00) @db.Decimal(10, 2)
  total_price     Decimal         @db.Decimal(10, 2)
  orders          orders          @relation(fields: [order_id], references: [order_id], onDelete: NoAction, onUpdate: NoAction, map: "orderitems_ibfk_1")
  products        products        @relation(fields: [product_id], references: [product_id], onDelete: NoAction, onUpdate: NoAction, map: "orderitems_ibfk_2")
  productvariants productvariants @relation(fields: [variant_id], references: [variant_id], onDelete: NoAction, onUpdate: NoAction, map: "orderitems_ibfk_3")
  productbatches  productbatches  @relation(fields: [batch_id], references: [batch_id], onDelete: NoAction, onUpdate: NoAction, map: "orderitems_ibfk_4")

  @@index([batch_id], map: "batch_id")
  @@index([order_id], map: "order_id")
  @@index([product_id], map: "product_id")
  @@index([variant_id], map: "variant_id")
}

model orders {
  order_id                                                        Int                  @id @default(autoincrement())
  customer_id                                                     Int
  billing_address_id                                              Int
  shipping_address_id                                             Int
  order_number                                                    String               @unique(map: "order_number") @db.VarChar(20)
  status                                                          orders_status?       @default(pending)
  subtotal                                                        Decimal              @db.Decimal(10, 2)
  tax_amount                                                      Decimal              @db.Decimal(10, 2)
  shipping_cost                                                   Decimal              @db.Decimal(10, 2)
  total_amount                                                    Decimal              @db.Decimal(10, 2)
  currency                                                        String?              @default("EUR") @db.Char(3)
  notes                                                           String?              @db.Text
  created_at                                                      DateTime?            @default(now()) @db.Timestamp(0)
  invoices                                                        invoices[]
  orderitems                                                      orderitems[]
  customers                                                       customers            @relation(fields: [customer_id], references: [customer_id], onDelete: NoAction, onUpdate: NoAction, map: "orders_ibfk_1")
  customeraddresses_orders_billing_address_idTocustomeraddresses  customeraddresses    @relation("orders_billing_address_idTocustomeraddresses", fields: [billing_address_id], references: [address_id], onDelete: NoAction, onUpdate: NoAction, map: "orders_ibfk_2")
  customeraddresses_orders_shipping_address_idTocustomeraddresses customeraddresses    @relation("orders_shipping_address_idTocustomeraddresses", fields: [shipping_address_id], references: [address_id], onDelete: NoAction, onUpdate: NoAction, map: "orders_ibfk_3")
  orderstatushistory                                              orderstatushistory[]
  payments                                                        payments[]
  shipments                                                       shipments[]

  @@index([billing_address_id], map: "billing_address_id")
  @@index([customer_id], map: "customer_id")
  @@index([shipping_address_id], map: "shipping_address_id")
}

model orderstatushistory {
  history_id Int                       @id @default(autoincrement())
  order_id   Int
  status     orderstatushistory_status
  changed_at DateTime?                 @default(now()) @db.Timestamp(0)
  notes      String?                   @db.Text
  orders     orders                    @relation(fields: [order_id], references: [order_id], onDelete: NoAction, onUpdate: NoAction, map: "orderstatushistory_ibfk_1")

  @@index([order_id], map: "order_id")
}

model payments {
  payment_id     Int             @id @default(autoincrement())
  order_id       Int
  method         payments_method
  transaction_id String?         @db.VarChar(100)
  amount         Decimal         @db.Decimal(10, 2)
  status         payments_status
  payment_date   DateTime?       @db.Timestamp(0)
  orders         orders          @relation(fields: [order_id], references: [order_id], onDelete: NoAction, onUpdate: NoAction, map: "payments_ibfk_1")

  @@index([order_id], map: "order_id")
}

model productattributes {
  product_attribute_id Int        @id @default(autoincrement())
  product_id           Int
  attribute_id         Int
  custom_value         String?    @db.VarChar(100)
  products             products   @relation(fields: [product_id], references: [product_id], onDelete: NoAction, onUpdate: NoAction, map: "productattributes_ibfk_1")
  attributes           attributes @relation(fields: [attribute_id], references: [attribute_id], onDelete: NoAction, onUpdate: NoAction, map: "productattributes_ibfk_2")

  @@unique([product_id, attribute_id], map: "product_id")
  @@index([attribute_id], map: "attribute_id")
}

model productbatches {
  batch_id       Int              @id @default(autoincrement())
  product_id     Int
  batch_number   String           @db.VarChar(50)
  harvest_year   Int              @db.Year
  expiry_date    DateTime?        @db.Date
  expiryalerts   expiryalerts[]
  orderitems     orderitems[]
  products       products         @relation(fields: [product_id], references: [product_id], onDelete: NoAction, onUpdate: NoAction, map: "productbatches_ibfk_1")
  productstock   productstock[]
  stockmovements stockmovements[]

  @@index([product_id], map: "product_id")
}

model productimages {
  image_id   Int      @id @default(autoincrement())
  product_id Int
  image_url  String   @db.VarChar(255)
  is_primary Boolean? @default(false)
  products   products @relation(fields: [product_id], references: [product_id], onDelete: NoAction, onUpdate: NoAction, map: "productimages_ibfk_1")

  @@index([product_id], map: "product_id")
}

model products {
  product_id          Int                   @id @default(autoincrement())
  subcategory_id      Int
  sku                 String?               @unique(map: "sku") @db.VarChar(50)
  price               Decimal               @db.Decimal(10, 2)
  seed_count          Int?
  is_featured         Boolean?              @default(false)
  created_at          DateTime?             @default(now()) @db.Timestamp(0)
  orderitems          orderitems[]
  productattributes   productattributes[]
  productbatches      productbatches[]
  productimages       productimages[]
  subcategories       subcategories         @relation(fields: [subcategory_id], references: [subcategory_id], onDelete: NoAction, onUpdate: NoAction, map: "products_ibfk_1")
  producttranslations producttranslations[]
  productvariants     productvariants[]

  @@index([subcategory_id], map: "subcategory_id")
}

model productstock {
  stock_id          Int             @id @default(autoincrement())
  variant_id        Int
  batch_id          Int
  warehouse_id      Int
  quantity          Int             @default(0)
  reserved_quantity Int?            @default(0)
  last_updated      DateTime?       @default(now()) @db.Timestamp(0)
  productvariants   productvariants @relation(fields: [variant_id], references: [variant_id], onDelete: NoAction, onUpdate: NoAction, map: "productstock_ibfk_1")
  productbatches    productbatches  @relation(fields: [batch_id], references: [batch_id], onDelete: NoAction, onUpdate: NoAction, map: "productstock_ibfk_2")
  warehouses        warehouses      @relation(fields: [warehouse_id], references: [warehouse_id], onDelete: NoAction, onUpdate: NoAction, map: "productstock_ibfk_3")

  @@unique([variant_id, batch_id, warehouse_id], map: "variant_id")
  @@index([batch_id], map: "batch_id")
  @@index([warehouse_id], map: "warehouse_id")
}

model producttranslations {
  translation_id Int       @id @default(autoincrement())
  product_id     Int
  language_id    String    @db.Char(2)
  name           String    @db.VarChar(100)
  description    String?   @db.Text
  sowing_period  String?   @db.VarChar(50)
  harvest_period String?   @db.VarChar(50)
  products       products  @relation(fields: [product_id], references: [product_id], onDelete: NoAction, onUpdate: NoAction, map: "producttranslations_ibfk_1")
  languages      languages @relation(fields: [language_id], references: [language_id], onDelete: NoAction, onUpdate: NoAction, map: "producttranslations_ibfk_2")

  @@unique([product_id, language_id], map: "product_id")
  @@index([language_id], map: "language_id")
}

model productvariants {
  variant_id     Int              @id @default(autoincrement())
  product_id     Int
  sku            String           @unique(map: "sku") @db.VarChar(50)
  attribute_set  Json?
  base_price     Decimal          @db.Decimal(10, 2)
  is_active      Boolean?         @default(true)
  orderitems     orderitems[]
  productstock   productstock[]
  products       products         @relation(fields: [product_id], references: [product_id], onDelete: NoAction, onUpdate: NoAction, map: "productvariants_ibfk_1")
  stockmovements stockmovements[]

  @@index([product_id], map: "product_id")
}

model shipments {
  shipment_id        Int               @id @default(autoincrement())
  order_id           Int
  carrier            String            @db.VarChar(50)
  tracking_number    String?           @db.VarChar(100)
  shipping_date      DateTime?         @db.Date
  estimated_delivery DateTime?         @db.Date
  status             shipments_status?
  orders             orders            @relation(fields: [order_id], references: [order_id], onDelete: NoAction, onUpdate: NoAction, map: "shipments_ibfk_1")

  @@index([order_id], map: "order_id")
}

model stockmovements {
  movement_id     Int                          @id @default(autoincrement())
  variant_id      Int
  batch_id        Int
  warehouse_id    Int
  quantity        Int
  movement_type   stockmovements_movement_type
  reference_id    Int?
  movement_date   DateTime?                    @default(now()) @db.Timestamp(0)
  expiry_date     DateTime?                    @db.Date
  productvariants productvariants              @relation(fields: [variant_id], references: [variant_id], onDelete: NoAction, onUpdate: NoAction, map: "stockmovements_ibfk_1")
  productbatches  productbatches               @relation(fields: [batch_id], references: [batch_id], onDelete: NoAction, onUpdate: NoAction, map: "stockmovements_ibfk_2")
  warehouses      warehouses                   @relation(fields: [warehouse_id], references: [warehouse_id], onDelete: NoAction, onUpdate: NoAction, map: "stockmovements_ibfk_3")

  @@index([batch_id], map: "batch_id")
  @@index([expiry_date], map: "expiry_date")
  @@index([variant_id], map: "variant_id")
  @@index([warehouse_id], map: "warehouse_id")
}

model subcategories {
  subcategory_id          Int                       @id @default(autoincrement())
  category_id             Int
  slug                    String?                   @unique(map: "slug") @db.VarChar(100)
  products                products[]
  categories              categories                @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction, map: "subcategories_ibfk_1")
  subcategorytranslations subcategorytranslations[]

  @@index([category_id], map: "category_id")
}

model subcategorytranslations {
  translation_id Int           @id @default(autoincrement())
  subcategory_id Int
  language_id    String        @db.Char(2)
  name           String        @db.VarChar(50)
  description    String?       @db.Text
  subcategories  subcategories @relation(fields: [subcategory_id], references: [subcategory_id], onDelete: NoAction, onUpdate: NoAction, map: "subcategorytranslations_ibfk_1")
  languages      languages     @relation(fields: [language_id], references: [language_id], onDelete: NoAction, onUpdate: NoAction, map: "subcategorytranslations_ibfk_2")

  @@unique([subcategory_id, language_id], map: "subcategory_id")
  @@index([language_id], map: "language_id")
}

model warehouses {
  warehouse_id   Int              @id @default(autoincrement())
  name           String           @db.VarChar(100)
  location       String?          @db.VarChar(100)
  productstock   productstock[]
  stockmovements stockmovements[]
}

enum orderstatushistory_status {
  pending
  paid
  shipped
  delivered
  cancelled
}

enum payments_method {
  credit_card
  paypal
  bank_transfer
  other
}

enum customeraddresses_type {
  billing
  shipping
}

enum expiryalerts_alert_type {
  warning
  critical
}

enum payments_status {
  pending
  completed
  failed
  refunded
}

enum orders_status {
  pending
  paid
  shipped
  delivered
  cancelled
}

enum stockmovements_movement_type {
  in
  out
}

enum shipments_status {
  preparing
  shipped
  delivered
  returned
}
